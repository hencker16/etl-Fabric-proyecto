{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "practicaFinal9"
		},
		"BlobStorage_Conn_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'BlobStorage_Conn'"
		},
		"MongoConn_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'MongoConn'"
		},
		"NeonConn_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'NeonConn'"
		},
		"MongoConn_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "test"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "practicaFinal9_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"BlobStorage_Conn_connectionString": {
						"value": "[parameters('BlobStorage_Conn_connectionString')]"
					},
					"MongoConn_connectionString": {
						"value": "[parameters('MongoConn_connectionString')]"
					},
					"NeonConn_connectionString": {
						"value": "[parameters('NeonConn_connectionString')]"
					},
					"MongoConn_properties_typeProperties_database": {
						"value": "[parameters('MongoConn_properties_typeProperties_database')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}